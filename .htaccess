# NOTE: /api/distance -> /.netlify/functions/distance requires a serverless backend; not portable to Apache.

# --- 3. Pretty URLs: redirect *.html and /dir/index.html to clean URLs ---
RewriteCond %{THE_REQUEST} \s/+(.+/)?index\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]
RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# --- 4. Serve extensionless URLs from their .html file ---
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ /$1.html [L]
</IfModule>

# --- 5. Custom error page (Netlify catch-all /* -> /404.html) ---
ErrorDocument 404 /404.html

# --- 6. Security & content headers (ported from netlify [[headers]]) ---
<IfModule mod_headers.c>
Header set X-Frame-Options "SAMEORIGIN"
Header set X-Content-Type-Options "nosniff"
Header set X-XSS-Protection "1; mode=block"
Header set Referrer-Policy "strict-origin-when-cross-origin"
Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
Header set Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

# Aggressive caching for static assets (Netlify /css/*, /js/*, /images/*)
<FilesMatch "\.(css|js|png|jpe?g|gif|webp|svg|ico|woff2?|ttf|eot)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
</IfModule>

# Content-type + caching for AI/discovery text files
<IfModule mod_headers.c>
<FilesMatch "\.(txt)$">
  Header set Cache-Control "public, max-age=86400"
</FilesMatch>
</IfModule>
<IfModule mod_mime.c>
  AddType text/plain .txt
</IfModule>

