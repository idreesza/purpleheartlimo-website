# ==========================================================================
# .htaccess for purpleheartlimo.com on Hostinger / Apache shared hosting
# AUTO-GENERATED from netlify.toml by scripts/gen_htaccess.py — do not edit
# by hand; edit netlify.toml and re-run the script so both stay in sync.
# ==========================================================================

Options -MultiViews -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
RewriteEngine On
RewriteBase /

# --- 1. Canonical domain: force HTTPS + strip www -> https://purpleheartlimo.com ---
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^(.*)$ https://purpleheartlimo.com/$1 [R=301,L]

